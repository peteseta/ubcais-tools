---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Facilitator Tools — UBC AI Safety"
  description="UBC AI Safety facilitator tools for running co-working sessions and structured debates."
>
  <main>
    <div class="content">
      <div class="eyebrow">UBC AI Safety</div>
      <h1 class="page-title">Facilitator Tools</h1>

      <div class="tools">
        <a href="/session" class="tool-card">
          <div class="card-inner">
            <div class="category-label">Session Board</div>
            <div class="tool-name">Co-working Session</div>
            <p class="tool-desc">
              Run co-working sessions with timers, question of the day, and
              structured stages.
            </p>
            <span class="open-link">Open Tool →</span>
          </div>
        </a>

        <a href="/spectrum" class="tool-card">
          <div class="card-inner">
            <div class="category-label">Discussion</div>
            <div class="tool-name">Oxford Style Debate</div>
            <p class="tool-desc">
              Facilitate structured debates with phase timers and audience
              voting.
            </p>
            <span class="open-link">Open Tool →</span>
          </div>
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    --theme-bg: 17, 17, 17;
    --theme-surface: 34, 34, 34;
    --theme-text: 249, 249, 249;
    --theme-accent: 204, 65, 37;

    min-height: 100vh;
    background: rgb(var(--theme-bg));
    color: rgb(var(--theme-text));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    box-sizing: border-box;
  }

  .content {
    width: 100%;
    max-width: 640px;
  }

  .eyebrow {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-variant: small-caps;
    color: rgba(var(--theme-text), 0.4);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-family: "IBM Plex Serif", Georgia, serif;
    font-size: 2.25rem;
    font-weight: 400;
    font-style: italic;
    color: rgb(var(--theme-text));
    margin: 0 0 2.5rem;
    line-height: 1.2;
  }

  .tools {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .tool-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: rgb(var(--theme-surface));
    border-left: 3px solid rgb(var(--theme-accent));
    border-radius: 0.375rem;
    box-shadow: 0 1px 6px rgba(0, 0, 0, 0.3);
    transition:
      box-shadow 0.15s,
      transform 0.1s;

    &:hover {
      box-shadow: 0 3px 14px rgba(0, 0, 0, 0.45);
      transform: translateY(-1px);

      .open-link {
        color: rgb(var(--theme-accent));
      }
    }
  }

  .card-inner {
    padding: 1.1rem 1.25rem;
  }

  .category-label {
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--theme-accent));
    margin-bottom: 0.3rem;
  }

  .tool-name {
    font-size: 1.05rem;
    font-weight: 500;
    color: rgb(var(--theme-text));
    margin-bottom: 0.4rem;
  }

  .tool-desc {
    font-size: 0.82rem;
    color: rgba(var(--theme-text), 0.5);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .open-link {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: rgba(var(--theme-text), 0.45);
    transition: color 0.15s;
  }
</style>
