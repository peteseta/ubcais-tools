---
import Layout from "../layouts/Layout.astro";
import presets from "../data/spectrum.json";
import debateConfig from "../data/debate-config.json";

const phases = debateConfig.phases;

const fmtTime = (s: number) => {
  if (s === 0) return '—';
  const m = Math.floor(s / 60);
  const sec = s % 60;
  return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
};

const fmtDuration = (s: number) => {
  if (s === 0) return '—';
  if (s >= 60 && s % 60 === 0) return `${s / 60} min`;
  return `${s} sec`;
};

const getPhase = (name: string) => phases.find(p => p.name === name);
const prepDur    = fmtDuration(getPhase('Group Prep')?.duration         ?? 0);
const openingDur = fmtDuration(getPhase('Opening — Disagree')?.duration ?? 0);
const debateDur  = fmtDuration(getPhase('Open Debate')?.duration        ?? 0);
const closingDur = fmtDuration(getPhase('Closing — Disagree')?.duration ?? 0);
---

<Layout title="Oxford Style Debate - UBC AI Safety">
  <main>
    <!-- Configuration Page -->
    <div id="configPage" class="config-page">
      <div class="config-container">
        <h1>Oxford Style <span>Debate</span></h1>

        <div class="config-section">
          <h2>Session Prompts</h2>
          <div class="presets-row">
            {presets.map((preset) => (
              <button class="btn-preset" data-preset={JSON.stringify(preset.prompts)}>{preset.name}</button>
            ))}
          </div>
          <div id="promptsList" class="prompts-list"></div>
          <button id="addPrompt" class="btn-primary">+ Add Prompt</button>
        </div>

        <div class="config-section format-section">
          <h2>Format</h2>
          <ol class="format-list">
            <li><span class="format-time">{prepDur}</span> Group prep</li>
            <li><span class="format-time">{openingDur}</span> Opening statements per side</li>
            <li><span class="format-time">{debateDur}</span> Open debate</li>
            <li><span class="format-time">{closingDur}</span> Closing statements per side</li>
            <li><span class="format-time">—</span> Audience votes on the winner</li>
          </ol>
        </div>

        <button id="startSession" class="btn-start">Start Session</button>
      </div>
    </div>

    <!-- Explainer Page -->
    <div id="explainerPage" class="explainer-page hidden">

      <h1 class="explainer-title"><span>How it works</span></h1>

      <!-- Room Layout -->
      <section class="exp-section">
        <h2 class="exp-label">Room Layout</h2>
        <div class="room-diagram">
          <div class="room-side room-disagree">
            <span class="room-side-label">Disagree</span>
          </div>
          <div class="room-aisle"></div>
          <div class="room-side room-agree">
            <span class="room-side-label">Agree</span>
          </div>
        </div>
        <p class="room-hint">Stand on the side that matches your view. Move if you change your mind.</p>
      </section>

      <!-- Screen Preview -->
      <section class="exp-section">
        <h2 class="exp-label">On Screen</h2>
        <div class="screen-preview">
          <div class="sp-side sp-left">DISAGREE</div>
          <div class="sp-center">
            <div class="sp-stepper">
              <div class="sp-dot"></div>
              <div class="sp-line"></div>
              <div class="sp-dot sp-dot-active"></div>
              <div class="sp-line"></div>
              <div class="sp-dot"></div>
              <div class="sp-line"></div>
              <div class="sp-dot"></div>
            </div>
            <div class="sp-prompt-block">
              <div class="sp-prompt-line sp-line-long"></div>
              <div class="sp-prompt-line sp-line-med"></div>
            </div>
            <div class="sp-timer">00:00</div>
          </div>
          <div class="sp-side sp-right">AGREE</div>
        </div>
      </section>

      <!-- Debate Flow -->
      <section class="exp-section">
        <h2 class="exp-label">Debate Format</h2>
        <div class="phase-stepper explainer-stepper">
          {phases.map((phase) => (
            <div class={`phase-step${phase.side ? ` side-${phase.side}` : ''}`}>
              <div class="step-dot"></div>
              <div class="step-label">{phase.short}</div>
              <div class="step-dur">{fmtTime(phase.duration)}</div>
            </div>
          ))}
        </div>
      </section>

      <div class="explainer-hint"><kbd>Space</kbd> to continue</div>
    </div>

    <!-- Display Page -->
    <div id="displayPage" class="display-page hidden">
      <div class="side-label left">DISAGREE</div>
      <div class="side-label right">AGREE</div>

      <div class="display-content">
        <!-- Phase stepper: rendered from debate-config.json at build time -->
        <div class="phase-stepper">
          {phases.map((phase) => (
            <div
              class={`phase-step${phase.side ? ` side-${phase.side}` : ''}`}
              data-name={phase.name}
              data-short={phase.short}
            >
              <div class="step-dot"></div>
              <div class="step-label">{phase.short}</div>
              <div class="step-dur">{fmtTime(phase.duration)}</div>
            </div>
          ))}
        </div>

        <div class="prompt-display">
          <div id="currentPrompt" class="current-prompt"></div>
          <div id="currentSubtitle" class="current-subtitle hidden"></div>
        </div>

        <div class="timer-container">
          <div id="timerDisplay" class="timer-display">00:00</div>
          <div id="sideIndicator" class="side-indicator hidden"></div>
        </div>
      </div>

      <!-- Controls: absolute bottom, tiny — facilitator only -->
      <div class="controls">
        <button id="prevPrompt">← Prev</button>
        <button id="startDebate">Start Debate</button>
        <button id="nextPhase" class="hidden">Next Phase →</button>
        <button id="stopTimer" class="hidden">Stop</button>
        <button id="nextPrompt">Next →</button>
        <button id="backToConfig">⚙ Config</button>
      </div>

      <div class="kbd-hints">
        <span><kbd>←</kbd><kbd>→</kbd> navigate</span>
        <span><kbd>B</kbd> start debate</span>
        <span><kbd>N</kbd> next phase</span>
        <span><kbd>Space</kbd> stop</span>
      </div>
    </div>
  </main>
</Layout>

<style lang="scss">
  @use "../colors.scss";

  $disagree-color: #dc2626;
  $agree-color: #16a34a;

  main {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    position: relative;
    font-family: "IBM Plex Sans", sans-serif;
  }

  .hidden {
    display: none !important;
  }

  // ── Config Page ───────────────────────────────────────────

  .config-page {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: colors.$primary-bg;
    padding: 2rem;
    overflow-y: auto;
  }

  .config-container {
    max-width: 640px;
    width: 100%;
    background: colors.$secondary-bg;
    padding: 2.5rem 3rem 3rem;
    border-radius: 0.375rem;
    border-top: 3px solid colors.$accent-primary;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6);

    h1 {
      font-size: 0.75rem;
      font-weight: 400;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: rgba(colors.$primary-text, 0.5);
      margin-bottom: 2.5rem;
      text-align: center;

      span {
        display: block;
        font-size: 2rem;
        font-weight: 400;
        font-family: "IBM Plex Serif", serif;
        font-style: italic;
        letter-spacing: -0.01em;
        text-transform: none;
        color: colors.$primary-text;
        margin-top: 0.2rem;
      }
    }

    h2 {
      font-size: 0.6rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: colors.$accent-primary;
      opacity: 0.7;
      margin-bottom: 0.75rem;
    }
  }

  .config-section {
    margin-bottom: 2rem;
  }

  // ── Presets ───────────────────────────────────────────────

  .presets-row {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .btn-preset {
    padding: 0.25rem 0.7rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    background: transparent;
    color: rgba(colors.$primary-text, 0.4);
    border: 1px solid rgba(colors.$primary-text, 0.12);
    border-radius: 2rem;
    cursor: pointer;
    font-family: "IBM Plex Sans", sans-serif;
    transition: all 0.15s;

    &:hover {
      background: colors.$accent-primary;
      border-color: colors.$accent-primary;
      color: white;
    }
  }

  // ── Prompt Items ──────────────────────────────────────────
  // These elements are created dynamically in JS so must use :global()

  :global(.prompts-list) {
    counter-reset: prompt-counter;
    margin-bottom: 0.5rem;
  }

  :global(.prompt-item) {
    counter-increment: prompt-counter;
    display: grid;
    grid-template-columns: 1.75rem 1fr 1.5rem;
    align-items: start;
    gap: 0.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(colors.$primary-text, 0.07);

    &:first-child {
      border-top: 1px solid rgba(colors.$primary-text, 0.07);
    }

    &::before {
      content: counter(prompt-counter);
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.68rem;
      color: colors.$accent-primary;
      opacity: 0.55;
      padding-top: 0.58rem;
      text-align: right;
    }

    button {
      background: none;
      border: none;
      color: rgba(colors.$primary-text, 0.15);
      cursor: pointer;
      font-size: 1.1rem;
      line-height: 1;
      padding: 0.45rem 0;
      transition: color 0.15s;
      text-align: center;

      &:hover {
        color: colors.$accent-primary;
      }
    }
  }

  :global(.prompt-inputs) {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.prompt-main) {
    width: 100%;
    background: transparent;
    border: none;
    padding: 0.5rem 0 0.25rem;
    font-size: 0.95rem;
    font-family: "IBM Plex Sans", sans-serif;
    color: colors.$primary-text;
    resize: none;
    overflow: hidden;
    min-height: 2rem;
    line-height: 1.6;

    &::placeholder {
      color: rgba(colors.$primary-text, 0.18);
      font-style: italic;
    }

    &:focus { outline: none; }
  }

  :global(.prompt-subtitle-input) {
    width: 100%;
    background: transparent;
    border: none;
    padding: 0 0 0.5rem;
    font-size: 0.8rem;
    font-family: "IBM Plex Sans", sans-serif;
    font-style: italic;
    color: rgba(colors.$primary-text, 0.35);
    resize: none;
    overflow: hidden;
    min-height: 1.2rem;
    line-height: 1.5;

    &::placeholder {
      color: rgba(colors.$primary-text, 0.12);
      font-style: italic;
    }

    &:focus { outline: none; }
  }

  // ── Format Section ────────────────────────────────────────

  .format-section {
    border-left: 2px solid rgba(colors.$accent-primary, 0.2);
    padding-left: 1rem;
  }

  .format-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: rgba(colors.$primary-text, 0.45);

    li {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
  }

  .format-time {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.72rem;
    color: colors.$accent-primary;
    opacity: 0.65;
    min-width: 3.25rem;
    flex-shrink: 0;
  }

  // ── Config Buttons ────────────────────────────────────────

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    background: none;
    color: rgba(colors.$primary-text, 0.35);
    border: none;
    cursor: pointer;
    font-family: "IBM Plex Sans", sans-serif;
    transition: color 0.15s;
    width: auto;

    &:hover {
      color: colors.$accent-primary;
    }
  }

  .btn-start {
    width: 100%;
    padding: 0.9rem 2rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    background: colors.$accent-primary;
    color: white;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    font-family: "IBM Plex Sans", sans-serif;
    transition: background 0.2s;
    margin-top: 2rem;

    &:hover {
      background: colors.$accent-dark;
    }

    &:active {
      transform: scale(0.99);
    }
  }

  // ── Explainer Page ────────────────────────────────────────

  .explainer-page {
    width: 100%;
    height: 100%;
    background: colors.$primary-bg;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    padding: 3rem 4rem 4rem;
    position: relative;
    overflow-y: auto;
  }

  .explainer-title {
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(colors.$primary-text, 0.3);
    text-align: center;
    margin: 0;

    span {
      display: block;
      font-family: "IBM Plex Serif", serif;
      font-style: italic;
      font-size: 2.4rem;
      font-weight: 400;
      letter-spacing: -0.01em;
      text-transform: none;
      color: colors.$primary-text;
      margin-top: 0.2rem;
    }
  }

  .exp-section {
    width: 100%;
    max-width: 860px;
  }

  .exp-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: colors.$accent-primary;
    opacity: 0.6;
    margin-bottom: 0.75rem;
  }

  .room-diagram {
    display: flex;
    align-items: stretch;
    height: 6rem;
    border-radius: 0.25rem;
    overflow: hidden;
    margin-bottom: 0.6rem;
  }

  .room-side {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .room-disagree {
    background: rgba($disagree-color, 0.08);
    border: 1px solid rgba($disagree-color, 0.2);
    border-right: none;
    border-radius: 0.25rem 0 0 0.25rem;
  }

  .room-agree {
    background: rgba($agree-color, 0.06);
    border: 1px solid rgba($agree-color, 0.16);
    border-left: none;
    border-radius: 0 0.25rem 0.25rem 0;
  }

  .room-aisle {
    width: 1px;
    background: rgba(colors.$primary-text, 0.06);
    border-left: 1px dashed rgba(colors.$primary-text, 0.1);
    border-right: none;
    flex-shrink: 0;
  }

  .room-side-label {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;

    .room-disagree & { color: $disagree-color; opacity: 0.7; }
    .room-agree &    { color: $agree-color; opacity: 0.7; }
  }

  .room-hint {
    font-size: 0.78rem;
    color: rgba(colors.$primary-text, 0.28);
    margin: 0;
    font-style: italic;
  }

  // ── Screen Preview ────────────────────────────────────────

  .screen-preview {
    height: 220px;
    width: auto;
    aspect-ratio: 16 / 9;
    max-width: 100%;
    display: flex;
    align-items: stretch;
    border: 1px solid rgba(colors.$primary-text, 0.07);
    border-radius: 0.3rem;
    overflow: hidden;
    background: rgba(colors.$primary-text, 0.015);
    position: relative;

    // left/right edge strips mimicking the display page
    &::before,
    &::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 2px;
    }
    &::before { left: 0; background: $disagree-color; opacity: 0.25; }
    &::after  { right: 0; background: $agree-color;    opacity: 0.25; }
  }

  .sp-side {
    width: 2.5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.55rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    user-select: none;
    opacity: 0.18;
  }

  .sp-left  { color: $disagree-color; transform: rotate(180deg); }
  .sp-right { color: $agree-color; }

  .sp-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    padding: 1.5rem 3rem;
  }

  .sp-stepper {
    display: flex;
    align-items: center;
    gap: 0;
    opacity: 0.2;
  }

  .sp-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: rgba(colors.$primary-text, 0.35);
    flex-shrink: 0;

    &.sp-dot-active {
      background: colors.$accent-primary;
      opacity: 1;
      box-shadow: 0 0 0 3px rgba(colors.$accent-primary, 0.15);
    }
  }

  .sp-stepper .sp-line {
    width: 3rem;
    height: 1px;
    background: rgba(colors.$primary-text, 0.15);
  }

  .sp-prompt-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
    width: 100%;
  }

  .sp-prompt-line {
    height: 0.6rem;
    border-radius: 0.3rem;
    background: rgba(colors.$primary-text, 0.12);

    &.sp-line-long { width: 72%; }
    &.sp-line-med  { width: 50%; }
  }

  .sp-timer {
    font-family: "IBM Plex Mono", monospace;
    font-size: 2.8rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: rgba(colors.$primary-text, 0.12);
    line-height: 1;
  }

  // ── Explainer Stepper ─────────────────────────────────────

  .explainer-stepper {
    pointer-events: none;

    .phase-step {
      .step-dot {
        width: 0.75rem;
        height: 0.75rem;
      }

      .step-label {
        font-size: 0.72rem;
        color: rgba(colors.$primary-text, 0.35);
      }

      .step-dur {
        font-size: 0.65rem;
        color: rgba(colors.$primary-text, 0.2);
      }

      &.side-agree .step-dot    { background: rgba($agree-color, 0.5); }
      &.side-disagree .step-dot { background: rgba($disagree-color, 0.5); }
      &.side-agree .step-label    { color: rgba($agree-color, 0.6); }
      &.side-disagree .step-label { color: rgba($disagree-color, 0.7); }
    }
  }

  .explainer-hint {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: rgba(colors.$primary-text, 0.25);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.35rem;

    kbd {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.55rem;
      background: rgba(colors.$primary-text, 0.08);
      border: 1px solid rgba(colors.$primary-text, 0.12);
      border-radius: 0.2rem;
      padding: 0.1rem 0.3rem;
    }
  }

  // ── Display Page ──────────────────────────────────────────

  .display-page {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: colors.$primary-bg;

    // Symmetric edge strips — balanced regardless of label word length
    &::before,
    &::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 3px;
      transition: opacity 0.4s ease;
    }

    &::before {
      left: 0;
      background: $disagree-color;
      opacity: 0.18;
    }

    &::after {
      right: 0;
      background: $agree-color;
      opacity: 0.18;
    }

    &:has(.side-label.left.highlight)::before  { opacity: 0.7; }
    &:has(.side-label.right.highlight)::after  { opacity: 0.7; }
  }

  .side-label {
    position: absolute;
    font-size: 3.5rem;
    font-weight: 800;
    font-family: "IBM Plex Sans", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transition: opacity 0.4s ease, font-size 0.3s ease;
    user-select: none;

    &.left {
      left: 1.25rem;
      top: 50%;
      transform: translateY(-50%) rotate(180deg);
      color: $disagree-color;
      opacity: 0.2;

      &.highlight {
        opacity: 0.85;
        font-size: 4rem;
      }
    }

    &.right {
      right: 1.25rem;
      top: 50%;
      transform: translateY(-50%);
      color: $agree-color;
      opacity: 0.2;

      &.highlight {
        opacity: 0.85;
        font-size: 4rem;
      }
    }
  }

  .display-content {
    width: 100%;
    max-width: 800px;
    padding: 2rem 5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
  }

  // ── Phase Stepper ─────────────────────────────────────────

  .phase-stepper {
    width: 100%;
    display: flex;
    align-items: flex-start;
  }

  .phase-step {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    position: relative;

    &:not(:first-child)::before {
      content: '';
      position: absolute;
      top: 0.3rem;
      right: 50%;
      width: 100%;
      height: 1px;
      background: rgba(colors.$primary-text, 0.08);
      z-index: 0;
      transition: background 0.4s;
    }

    &.done:not(:first-child)::before,
    &.active:not(:first-child)::before {
      background: rgba(colors.$accent-primary, 0.25);
    }

    .step-dot {
      width: 0.6rem;
      height: 0.6rem;
      border-radius: 50%;
      background: rgba(colors.$primary-text, 0.12);
      z-index: 1;
      position: relative;
      flex-shrink: 0;
      transition: background 0.3s, box-shadow 0.3s;
    }

    .step-label {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.65rem;
      letter-spacing: 0.04em;
      color: rgba(colors.$primary-text, 0.25);
      text-align: center;
      line-height: 1.2;
      transition: color 0.3s;
    }

    .step-dur {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.58rem;
      color: rgba(colors.$primary-text, 0.12);
      text-align: center;
      transition: color 0.3s;
    }

    &.active {
      .step-dot {
        background: colors.$accent-primary;
        box-shadow: 0 0 0 4px rgba(colors.$accent-primary, 0.15);
      }
      .step-label {
        color: colors.$accent-primary;
        font-size: 0.72rem;
        font-weight: 600;
      }
      .step-dur { color: colors.$accent-primary; }
    }

    &.done {
      .step-dot { background: rgba(colors.$primary-text, 0.2); }
      .step-label, .step-dur { color: rgba(colors.$primary-text, 0.2); }
    }

    &.side-disagree.active {
      .step-dot {
        background: $disagree-color;
        box-shadow: 0 0 0 4px rgba($disagree-color, 0.15);
      }
      .step-label, .step-dur { color: $disagree-color; }
    }

    &.side-agree.active {
      .step-dot {
        background: $agree-color;
        box-shadow: 0 0 0 4px rgba($agree-color, 0.15);
      }
      .step-label, .step-dur { color: $agree-color; }
    }
  }

  // ── Prompt Display ────────────────────────────────────────

  .prompt-display {
    width: 100%;
  }

  .current-prompt {
    font-size: 2.5rem;
    font-weight: 400;
    font-family: "IBM Plex Serif", serif;
    font-style: italic;
    text-align: center;
    text-wrap: balance;
    color: colors.$primary-text;
    line-height: 1.1;
    min-height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .current-subtitle {
    font-size: 1rem;
    font-family: "IBM Plex Sans", sans-serif;
    text-align: center;
    text-wrap: balance;
    color: rgba(colors.$primary-text, 0.38);
    line-height: 1.55;
    margin-top: 2.5rem;
  }

  .timer-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .timer-display {
    font-size: 7rem;
    font-weight: 300;
    text-align: center;
    color: colors.$primary-text;
    font-family: "IBM Plex Mono", monospace;
    line-height: 1;
    letter-spacing: -0.02em;

    &.warning {
      color: colors.$accent-primary;
      animation: pulse 1s infinite;
    }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  .side-indicator {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-align: center;
    padding: 0.35rem 1.1rem;
    border-radius: 2rem;
    color: white;
    text-transform: uppercase;

    &.disagree {
      background: $disagree-color;
    }

    &.agree {
      background: $agree-color;
    }
  }

  .controls {
    position: absolute;
    bottom: 2.75rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.25rem;
    white-space: nowrap;

    button {
      padding: 0.2rem 0.55rem;
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: transparent;
      color: rgba(colors.$primary-text, 0.2);
      border: 1px solid rgba(colors.$primary-text, 0.07);
      border-radius: 2rem;
      cursor: pointer;
      font-family: "IBM Plex Sans", sans-serif;
      transition: all 0.15s;

      &:hover {
        color: rgba(colors.$primary-text, 0.6);
        border-color: rgba(colors.$primary-text, 0.15);
      }

      &#startDebate,
      &#nextPhase {
        background: rgba(colors.$accent-primary, 0.7);
        color: white;
        border-color: transparent;

        &:hover {
          background: colors.$accent-primary;
        }
      }

      &:disabled {
        opacity: 0.15;
        cursor: not-allowed;
        &:hover {
          color: rgba(colors.$primary-text, 0.2);
          border-color: rgba(colors.$primary-text, 0.07);
        }
      }
    }
  }

  .kbd-hints {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 1.25rem;
    opacity: 0.3;
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    color: colors.$primary-text;
    white-space: nowrap;

    span {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    kbd {
      font-family: "IBM Plex Mono", monospace;
      font-size: 0.55rem;
      background: rgba(colors.$primary-text, 0.1);
      border: 1px solid rgba(colors.$primary-text, 0.15);
      border-radius: 0.2rem;
      padding: 0.1rem 0.3rem;
    }
  }

  @media (max-width: 768px) {
    .config-container {
      padding: 2rem 1.5rem 2.5rem;
    }

    .display-content {
      padding: 2rem 4rem;
    }

    .current-prompt {
      font-size: 1.75rem;
    }

    .timer-display {
      font-size: 4.5rem;
    }

    .side-label {
      font-size: 2.5rem;

      &.highlight {
        font-size: 3rem;
      }
    }
  }
</style>

<script>
  import debateConfig from "../data/debate-config.json";
  import { formatPhaseTime, normalizePhases } from "../lib/spectrumTimer.js";

  // ── Types ─────────────────────────────────────────────────

  type Phase = { name: string; duration: number; side?: 'disagree' | 'agree' };
  type Prompt = { text: string; subtitle: string };

  // ── Phases from debate-config.json ────────────────────────

  const PHASES: Phase[] = normalizePhases(debateConfig.phases);

  // ── State ─────────────────────────────────────────────────

  let prompts: Prompt[] = [];
  let currentPromptIndex = 0;
  let timerInterval: number | null = null;
  let currentPhaseIndex = -1;

  // ── Elements ──────────────────────────────────────────────

  const configPage      = document.getElementById('configPage')      as HTMLDivElement;
  const explainerPage   = document.getElementById('explainerPage')   as HTMLDivElement;
  const displayPage     = document.getElementById('displayPage')     as HTMLDivElement;
  const promptsList     = document.getElementById('promptsList')     as HTMLDivElement;
  const addPromptBtn    = document.getElementById('addPrompt')       as HTMLButtonElement;
  const startSessionBtn = document.getElementById('startSession')    as HTMLButtonElement;

  const currentPromptEl   = document.getElementById('currentPrompt')   as HTMLDivElement;
  const currentSubtitleEl = document.getElementById('currentSubtitle') as HTMLDivElement;
  const timerDisplay      = document.getElementById('timerDisplay')    as HTMLDivElement;
  const sideIndicator     = document.getElementById('sideIndicator')   as HTMLDivElement;
  const leftLabel  = document.querySelector('.side-label.left')  as HTMLDivElement;
  const rightLabel = document.querySelector('.side-label.right') as HTMLDivElement;

  const prevPromptBtn  = document.getElementById('prevPrompt')  as HTMLButtonElement;
  const nextPromptBtn  = document.getElementById('nextPrompt')  as HTMLButtonElement;
  const startDebateBtn = document.getElementById('startDebate') as HTMLButtonElement;
  const nextPhaseBtn   = document.getElementById('nextPhase')   as HTMLButtonElement;
  const stopTimerBtn   = document.getElementById('stopTimer')   as HTMLButtonElement;
  const backToConfigBtn = document.getElementById('backToConfig') as HTMLButtonElement;

  const phaseSteps = Array.from(document.querySelectorAll<HTMLElement>('#displayPage .phase-step'));

  // ── Helpers ───────────────────────────────────────────────

  const setHidden = (el: HTMLElement, hidden: boolean) => {
    el.classList.toggle('hidden', hidden);
  };

  const playSound = () => {
    const ctx = new AudioContext();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.frequency.value = 800;
    osc.type = 'sine';
    gain.gain.setValueAtTime(0.3, ctx.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.01, ctx.currentTime + 0.5);
    osc.start(ctx.currentTime);
    osc.stop(ctx.currentTime + 0.5);
  };

  const autoResize = (ta: HTMLTextAreaElement) => {
    ta.style.height = 'auto';
    ta.style.height = ta.scrollHeight + 'px';
  };

  const showPage = (page: HTMLDivElement) => {
    setHidden(configPage, page !== configPage);
    setHidden(explainerPage, page !== explainerPage);
    setHidden(displayPage, page !== displayPage);
  };

  const collectPrompts = () =>
    Array.from(promptsList.querySelectorAll<HTMLDivElement>('.prompt-item'))
      .map(item => ({
        text: (item.querySelector('.prompt-main') as HTMLTextAreaElement)?.value.trim() ?? '',
        subtitle: (item.querySelector('.prompt-subtitle-input') as HTMLTextAreaElement)?.value.trim() ?? '',
      }))
      .filter(p => p.text.length > 0);

  const setPromptIndex = (nextIndex: number) => {
    currentPromptIndex = nextIndex;
    updatePromptDisplay();
    updateNavigationButtons();
    resetToIdle();
  };

  const setTimerControls = ({
    showStart = false,
    showNext = false,
    showStop = false,
  }: {
    showStart?: boolean;
    showNext?: boolean;
    showStop?: boolean;
  } = {}) => {
    setHidden(startDebateBtn, !showStart);
    setHidden(nextPhaseBtn, !showNext);
    setHidden(stopTimerBtn, !showStop);
  };

  // ── Config page: prompt inputs ────────────────────────────

  const addPromptInput = (text = '', subtitle = '') => {
    const item = document.createElement('div');
    item.className = 'prompt-item';

    const inputs = document.createElement('div');
    inputs.className = 'prompt-inputs';

    const mainTa = document.createElement('textarea');
    mainTa.className = 'prompt-main';
    mainTa.placeholder = 'Enter a debate prompt…';
    mainTa.value = text;
    mainTa.rows = 1;
    mainTa.addEventListener('input', () => autoResize(mainTa));
    if (text) requestAnimationFrame(() => autoResize(mainTa));

    const subTa = document.createElement('textarea');
    subTa.className = 'prompt-subtitle-input';
    subTa.placeholder = 'Context or framing (optional)…';
    subTa.value = subtitle;
    subTa.rows = 1;
    subTa.addEventListener('input', () => autoResize(subTa));
    if (subtitle) requestAnimationFrame(() => autoResize(subTa));

    inputs.appendChild(mainTa);
    inputs.appendChild(subTa);

    const removeBtn = document.createElement('button');
    removeBtn.textContent = '×';
    removeBtn.setAttribute('aria-label', 'Remove prompt');
    removeBtn.addEventListener('click', () => item.remove());

    item.appendChild(inputs);
    item.appendChild(removeBtn);
    promptsList.appendChild(item);
  };

  document.querySelectorAll<HTMLButtonElement>('.btn-preset').forEach(btn => {
    btn.addEventListener('click', () => {
      const raw: Array<string | { text: string; subtitle?: string }> = JSON.parse(btn.dataset.preset!);
      promptsList.innerHTML = '';
      raw.forEach(p => {
        const text = typeof p === 'string' ? p : p.text;
        const subtitle = typeof p === 'string' ? '' : (p.subtitle ?? '');
        addPromptInput(text, subtitle);
      });
    });
  });

  addPromptInput();
  addPromptBtn.addEventListener('click', () => addPromptInput());

  startSessionBtn.addEventListener('click', () => {
    prompts = collectPrompts();

    if (prompts.length === 0) {
      alert('Please add at least one prompt');
      return;
    }
    currentPromptIndex = 0;
    showPage(explainerPage);
  });

  // ── Display page ──────────────────────────────────────────

  const showDisplayPage = () => {
    showPage(displayPage);
    updatePromptDisplay();
    updateNavigationButtons();
    resetToIdle();
  };

  const showConfigPage = () => {
    showPage(configPage);
    clearTimer();
  };

  const updatePromptDisplay = () => {
    if (prompts.length > 0) {
      const p = prompts[currentPromptIndex];
      currentPromptEl.textContent = p.text;
      currentSubtitleEl.textContent = p.subtitle;
      currentSubtitleEl.classList.toggle('hidden', !p.subtitle);
    }
  };

  const updateNavigationButtons = () => {
    prevPromptBtn.disabled = currentPromptIndex === 0;
    nextPromptBtn.disabled = currentPromptIndex === prompts.length - 1;
  };

  const updateStepper = (activeIndex: number) => {
    phaseSteps.forEach((step, i) => {
      step.classList.remove('active', 'done');
      const label = step.querySelector('.step-label') as HTMLElement;
      if (i < activeIndex) {
        step.classList.add('done');
        label.textContent = step.dataset.short!;
      } else if (i === activeIndex) {
        step.classList.add('active');
        label.textContent = step.dataset.name!;
      } else {
        label.textContent = step.dataset.short!;
      }
    });
  };

  const resetStepper = () => {
    phaseSteps.forEach(s => {
      s.classList.remove('active', 'done');
      const label = s.querySelector('.step-label') as HTMLElement;
      label.textContent = s.dataset.short!;
    });
  };

  // ── Timer ─────────────────────────────────────────────────

  const clearTimer = () => {
    if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  };

  const resetToIdle = () => {
    clearTimer();
    currentPhaseIndex = -1;
    timerDisplay.textContent = '00:00';
    timerDisplay.classList.remove('warning');
    setHidden(sideIndicator, true);
    leftLabel.classList.remove('highlight');
    rightLabel.classList.remove('highlight');
    setTimerControls({ showStart: true });
    resetStepper();
  };

  const updateSideDisplay = (side?: 'disagree' | 'agree') => {
    if (side) {
      sideIndicator.textContent = side === 'disagree' ? 'DISAGREE SPEAKS' : 'AGREE SPEAKS';
      sideIndicator.className = `side-indicator ${side}`;
      setHidden(sideIndicator, false);
      leftLabel.classList.toggle('highlight', side === 'disagree');
      rightLabel.classList.toggle('highlight', side === 'agree');
    } else {
      setHidden(sideIndicator, true);
      leftLabel.classList.remove('highlight');
      rightLabel.classList.remove('highlight');
    }
  };

  const runPhase = (index: number) => {
    clearTimer();
    currentPhaseIndex = index;
    const phase = PHASES[index];

    if (!phase) {
      resetToIdle();
      return;
    }

    timerDisplay.classList.remove('warning');
    updateSideDisplay(phase.side);
    updateStepper(index);

    setTimerControls();

    if (phase.duration === 0) {
      timerDisplay.textContent = '—';
      return;
    }

    let timeLeft = phase.duration;
    timerDisplay.textContent = formatPhaseTime(timeLeft);
    setTimerControls({ showStop: true });

    timerInterval = window.setInterval(() => {
      timeLeft--;
      timerDisplay.textContent = formatPhaseTime(timeLeft);
      if (timeLeft <= 10 && timeLeft > 0) timerDisplay.classList.add('warning');
      if (timeLeft <= 0) {
        clearTimer();
        playSound();
        timerDisplay.classList.add('warning');
        setTimerControls({ showNext: index < PHASES.length - 1 });
      }
    }, 1000);
  };

  const advancePhase = () => {
    const next = currentPhaseIndex + 1;
    if (next < PHASES.length) runPhase(next);
  };

  startDebateBtn.addEventListener('click', () => runPhase(0));
  nextPhaseBtn.addEventListener('click', advancePhase);

  stopTimerBtn.addEventListener('click', () => {
    clearTimer();
    timerDisplay.classList.remove('warning');
    setTimerControls({ showNext: currentPhaseIndex < PHASES.length - 1 });
  });

  prevPromptBtn.addEventListener('click', () => {
    if (currentPromptIndex > 0) setPromptIndex(currentPromptIndex - 1);
  });

  nextPromptBtn.addEventListener('click', () => {
    if (currentPromptIndex < prompts.length - 1) setPromptIndex(currentPromptIndex + 1);
  });

  backToConfigBtn.addEventListener('click', showConfigPage);

  document.addEventListener('keydown', (e) => {
    if (!configPage.classList.contains('hidden')) return;
    if (!explainerPage.classList.contains('hidden')) {
      if (e.key === ' ' || e.key === 'Enter') {
        e.preventDefault();
        showDisplayPage();
      }
      return;
    }
    if (e.key === 'ArrowLeft' && !prevPromptBtn.disabled) prevPromptBtn.click();
    else if (e.key === 'ArrowRight' && !nextPromptBtn.disabled) nextPromptBtn.click();
    else if ((e.key === 'b' || e.key === 'B') && !startDebateBtn.classList.contains('hidden')) runPhase(0);
    else if ((e.key === 'n' || e.key === 'N') && !nextPhaseBtn.classList.contains('hidden')) advancePhase();
    else if ((e.key === 's' || e.key === 'S' || e.key === ' ') && !stopTimerBtn.classList.contains('hidden')) {
      e.preventDefault(); stopTimerBtn.click();
    }
  });
</script>
</Layout>
