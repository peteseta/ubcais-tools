---
import grainImage from "@/assets/images/session-board/grain.png";
import lightImage from "@/assets/images/session-board/light.png";
import SessionBoardAudiencePage from "@/components/SessionBoard/SessionBoardAudiencePage.vue";
import Layout from "@/layouts/Layout.astro";
import { Picture } from "astro:assets";
---

<Layout
  title="Session Board — Display"
  description="UBC AI Safety session board audience display."
>
  <a href="/" class="session-display-back-link">← Back</a>
  <div class="display-wrapper">
    <SessionBoardAudiencePage client:only="vue">
      <Picture
        slot="grain"
        src={grainImage}
        formats={["avif", "webp"]}
        widths={[640, 750, 828, 1080, 1200, 1920, 2048, 3840]}
        quality="high"
        alt=""
        aria-hidden
      />
      <Picture
        slot="light"
        src={lightImage}
        formats={["avif", "webp"]}
        widths={[640, 750, 828, 1080, 1200, 1920, 2048, 3840]}
        quality="high"
        alt=""
        aria-hidden
      />
    </SessionBoardAudiencePage>
  </div>
</Layout>

<style lang="scss" is:global>
  @use "inter-ui/variable" with (
    $inter-font-display: swap,
    $inter-font-path: "inter-ui/variable"
  );

  @include variable.all;

  html,
  body {
    height: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;
  }

  body {
    font-family: "InterVariable", system-ui;
    background-color: #f6f2ee;
  }

  .display-wrapper {
    height: 100vh;
  }

  .session-display-back-link {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: rgba(44, 37, 31, 0.72);
    background: rgba(246, 242, 238, 0.78);
    border: 1px solid rgba(44, 37, 31, 0.12);
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    backdrop-filter: blur(10px);
  }

  .session-display-back-link:hover {
    color: rgb(44, 37, 31);
    border-color: rgba(44, 37, 31, 0.24);
    background: rgba(246, 242, 238, 0.92);
  }
</style>
