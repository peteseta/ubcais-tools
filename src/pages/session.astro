---
import grainImage from "@/assets/images/session-board/grain.png";
import lightImage from "@/assets/images/session-board/light.png";
import FacilitatorPanel from "@/components/SessionBoard/FacilitatorPanel.vue";
import Layout from "@/layouts/Layout.astro";
import { Picture } from "astro:assets";
---

<Layout
  title="Co-working Session — UBC AI Safety"
  description="UBC AI Safety co-working session facilitator panel."
>
  <FacilitatorPanel client:only="vue">
    <Picture
      slot="grain"
      src={grainImage}
      formats={["avif", "webp"]}
      widths={[640, 750, 828, 1080, 1200, 1920, 2048, 3840]}
      quality="high"
      alt=""
      aria-hidden
    />
    <Picture
      slot="light"
      src={lightImage}
      formats={["avif", "webp"]}
      widths={[640, 750, 828, 1080, 1200, 1920, 2048, 3840]}
      quality="high"
      alt=""
      aria-hidden
    />
  </FacilitatorPanel>
</Layout>

<style lang="scss" is:global>
  @use "inter-ui/variable" with (
    $inter-font-display: swap,
    $inter-font-path: "inter-ui/variable"
  );

  @include variable.all;

  html,
  body {
    height: 100%;
    overflow: hidden;
  }

  body {
    font-family: "InterVariable", system-ui;
    background-color: #111;
  }

</style>
